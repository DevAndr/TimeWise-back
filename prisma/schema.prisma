generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApiToken {
  id        String   @id @default(uuid())
  name      String
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities    Activity[]
  appActivities AppActivity[]
  domainGoals   DomainGoal[]

  @@map("api_tokens")
}

model Activity {
  id        String    @id @default(uuid())
  domain    String
  url       String?
  title     String?
  duration  Int // seconds spent on the site
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  apiTokenId String
  apiToken   ApiToken @relation(fields: [apiTokenId], references: [id], onDelete: Cascade)

  @@index([apiTokenId, domain])
  @@index([startedAt])
  @@map("activities")
}

model AppActivity {
  id          String   @id @default(uuid())
  appName     String
  windowTitle String?
  duration    Int // milliseconds
  startedAt   DateTime
  endedAt     DateTime
  createdAt   DateTime @default(now())

  apiTokenId String
  apiToken   ApiToken @relation(fields: [apiTokenId], references: [id], onDelete: Cascade)

  @@index([apiTokenId, appName])
  @@index([startedAt])
  @@map("app_activities")
}

model DomainGoal {
  id             String @id @default(uuid())
  domain         String
  dailyGoal      Int    @default(7200) // seconds (default 2 hours)
  currentProgress Int   @default(0) // seconds spent today
  date           DateTime @db.Date // the day this progress applies to

  apiTokenId String
  apiToken   ApiToken @relation(fields: [apiTokenId], references: [id], onDelete: Cascade)

  @@unique([apiTokenId, domain, date])
  @@index([apiTokenId, domain])
  @@map("domain_goals")
}
